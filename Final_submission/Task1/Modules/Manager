        author = input("Author: ")
        try:
            total_copies = int(input("Total Copies: "))
            available_copies = int(input("Available Copies: "))
        except ValueError:
            print("Error: Copies must be numbers.")
            return

        location = input("Location: ")

        new_book = {
            "isbn": isbn,
            "title": title,
            "author": author,
            "total_copies": total_copies,
            "available_copies": available_copies,
            "location": location
        }

        data.books.append(new_book)
        print(f"Book '{title}' added")

    def delete_book_avaliable(self):
        print("Please enter the title of the book you want to delete: ")
        founder = input().lower()
        found = []
        for book in data.books:
            if founder == book["title"].lower():
                found.append(book)
        if len(found) > 1:
            print("Incorrect title, multiple books found")
        elif len(found) == 1:
            self.delete_book(found[0])
        else:
            print("Book not found")

    def delete_book(self, target_book):
